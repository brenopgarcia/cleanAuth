{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=cleanauth.db"
  },
  "ForwardedHeaders": {
    "TrustedProxies": [],
    "TrustedNetworks": [],
    "ForwardLimit": 2
  },
  "Jwt": {
    "Secret": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "CleanAuth",
    "Audience": "CleanAuthClients",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 1
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
